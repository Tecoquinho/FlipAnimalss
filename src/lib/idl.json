{
  "version": "0.1.0",
  "name": "flip_animals",
  "instructions": [
    {
      "name": "initializePot",
      "accounts": [
        { "name": "pot", "isMut": true, "isSigner": false },
        { "name": "admin", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [{ "name": "roomId", "type": "string" }]
    },
    {
      "name": "placeBet",
      "accounts": [
        { "name": "pot", "isMut": true, "isSigner": false },
        { "name": "player", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "animalId", "type": "u8" },
        { "name": "amount", "type": "u64" }
      ]
    },
    {
      "name": "resolvePot",
      "accounts": [
        { "name": "pot", "isMut": true, "isSigner": false },
        { "name": "admin", "isMut": true, "isSigner": true },
        { "name": "winnerAccount", "isMut": true, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [{ "name": "winnerAnimalId", "type": "u8" }]
    }
  ],
  "accounts": [
    {
      "name": "Pot",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "roomId", "type": "string" },
          { "name": "admin", "type": "publicKey" },
          { "name": "totalAmount", "type": "u64" },
          { "name": "isActive", "type": "boolean" },
          { "name": "bets", "type": { "vec": { "defined": "Bet" } } }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "Bet",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "player", "type": "publicKey" },
          { "name": "amount", "type": "u64" },
          { "name": "animalId", "type": "u8" }
        ]
      }
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "NoWinners",
      "msg": "No winners found for the selected animal."
    }
  ]
}
